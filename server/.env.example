# Copy this file to .env and fill in your values
# DO NOT commit .env to git

# Node environment
NODE_ENV=development

# Port (DigitalOcean App Platform injects this automatically — do not set it on DO)
PORT=3001

# Groq AI key — used for /api/search and /api/station-guide
GROQ_API_KEY=your_groq_key_here

# ElevenLabs key — used for /api/tts (text-to-speech)
# Leave empty to fall back to expo-speech on device
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# CORS allowed origins (comma-separated list, e.g. https://myapp.com)
# Leave empty to allow all origins (required for Expo Go development)
ALLOWED_ORIGINS=
